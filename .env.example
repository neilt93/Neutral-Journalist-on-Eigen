# EigenAI - OpenAI-compatible inference endpoint
# Production: https://eigenai.eigencloud.xyz/v1 (get key from EigenCloud)
# Local dev:  https://api.openai.com/v1 (use your OpenAI key)
EIGENAI_API_BASE=https://eigenai.eigencloud.xyz/v1
EIGENAI_API_KEY=your-eigenai-key
EIGENAI_MODEL=gpt-4o
# Optional: separate model for slant eval (default: same as above)
EIGENAI_EVALUATOR_MODEL=
EIGENAI_INFERENCE_SEED=42  # Deterministic inference for verifiability

# EigenCompute
EIGENCOMPUTE_NODE_ID=
EIGENCOMPUTE_TEE_ATTESTATION_ENDPOINT=

# Agent Wallet (managed by EigenCompute TEE in production)
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# Attestation
ATTESTATION_CONTRACT_ADDRESS=
ATTESTATION_RPC_URL=https://mainnet.infura.io/v3/your-key

# News Sources API Keys (optional, for premium sources)
NEWSAPI_KEY=
GUARDIAN_API_KEY=

# Publishing
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Agent Config
AGENT_LOOP_INTERVAL_MINUTES=60
SLANT_THRESHOLD=0.15  # Max acceptable slant score before recalibration
SOURCE_BALANCE_THRESHOLD=0.4
MAX_CALIBRATION_ROUNDS=3
REQUIRE_ONCHAIN_ATTESTATION=true
